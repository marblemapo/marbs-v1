# Copy this file to .env.local and fill in real values.
# Find these at: Supabase dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-side only. Full DB admin access. Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Finnhub — free tier at https://finnhub.io (signup for key, 60 req/min).
# Used for stock/ETF search + quote prices.
FINNHUB_API_KEY=your_finnhub_key_here

# Alchemy — free tier at https://www.alchemy.com (300M CU/mo).
# Used for on-chain balance reads when a user connects an Ethereum wallet.
# Server-side only; never exposed to the browser.
ALCHEMY_API_KEY=your_alchemy_key_here
